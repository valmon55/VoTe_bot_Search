<Window x:Class="KFA.Vote_Search.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KFA.Vote_Search"
        xmlns:viewModels="clr-namespace:KFA.Vote_Search.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Menu>
            <ListView Name="MessList" ItemsSource="{Binding messages }">
                <ListView.View>
                    <GridView>
                        <GridViewColumn DisplayMemberBinding="{Binding Path=ChatId}" Width="100">
                            <GridViewColumnHeader Content="ChatId"></GridViewColumnHeader>
                        </GridViewColumn>
                        <GridViewColumn DisplayMemberBinding="{Binding Path=MessageDate}" Width="150">
                            <GridViewColumnHeader Content="MessageDate"></GridViewColumnHeader>
                        </GridViewColumn>
                        <GridViewColumn DisplayMemberBinding="{Binding Path=LanguageCode}" Width="50">
                            <GridViewColumnHeader Content="Lang"></GridViewColumnHeader>
                        </GridViewColumn>
                        <GridViewColumn DisplayMemberBinding="{Binding Path=Message}" Width="500">
                            <GridViewColumnHeader Content="Message"></GridViewColumnHeader>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Menu>
    </Grid>
</Window>
